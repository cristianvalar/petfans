# Django Settings
SECRET_KEY=tu-secret-key-super-segura-de-minimo-50-caracteres-aqui
DEBUG=False
DJANGO_SETTINGS_MODULE=petfans.settings.prod
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# Database
# Opción 1: URL completa
DATABASE_URL=postgresql://user:password@host:5432/database

# Opción 2: Variables individuales
POSTGRES_DB=petfans
POSTGRES_USER=petfans
POSTGRES_PASSWORD=password-seguro-aqui
POSTGRES_HOST=db-host
POSTGRES_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-de-gmail
EMAIL_USE_TLS=True

# CORS - Agregar dominios permitidos separados por comas
CORS_ALLOWED_ORIGINS=https://tuapp.com,https://www.tuapp.com

# Media Files (opcional - para S3/Cloudinary en el futuro)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
